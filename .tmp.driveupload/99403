export function GeneratedSetupPreview({
  setup,
  editable,
  onChangeSummary,
  onUpdateCategoryName,
  onDeleteCategory,
  onAddCategory,
  onAddKpi,
  onUpdateKpi,
  onDeleteKpi,
  onAddActivity,
  onUpdateActivity,
  onDeleteActivity,
  onUpdateReminderPreference,
  onAddRelationship,
  onUpdateRelationship,
  onDeleteRelationship,
}: GeneratedSetupPreviewProps) {
  const { theme } = useTheme();
  const { t } = useTranslation();
  const [expandedCategoryIds, setExpandedCategoryIds] = useState<Record<string, boolean>>({});

  const summary = useMemo(() => {
    const kpiCount = setup.categories.reduce((sum, category) => sum + category.kpis.length, 0);
    const activities = setup.categories.flatMap((category) =>
      category.kpis.flatMap((kpi) => kpi.activities)
    );

    return {
      categories: setup.categories.length,
      kpis: kpiCount,
      activities: activities.length,
      recommended: activities.filter((activity) => activity.recommended).length,
    };
  }, [setup.categories]);

  const expandedLookup = useMemo(() => {
    const nextLookup: Record<string, boolean> = {};
    for (const category of setup.categories) {
      nextLookup[category.id] = expandedCategoryIds[category.id] ?? false;
    }
    return nextLookup;
  }, [expandedCategoryIds, setup.categories]);

  return (
    <View style={styles.container}>
      <SectionCard>
        <Text style={[styles.sectionTitle, { color: theme.textPrimary }]}>
          {t('onboarding.preview.generatedSetup')}
        </Text>
        <Text style={[styles.sectionSubtitle, { color: theme.textSecondary }]}>
          {t('onboarding.preview.generatedSetupSubtitle')}
        </Text>

        <View style={styles.singleField}>
          <InputLabel>{t('onboarding.preview.summaryLabel')}</InputLabel>
          <PreviewTextInput editable={editable} value={setup.summary} onChangeText={onChangeSummary} />
        </View>
      </SectionCard>

      <SectionCard>
        <View style={styles.headerRow}>
          <View style={{ flex: 1 }}>
            <Text style={[styles.sectionTitle, { color: theme.textPrimary }]}>
              Life Buddy built your starter system
            </Text>
            <Text style={[styles.sectionSubtitle, { color: theme.textSecondary }]}>
              Start with the summary, then open details only where you want to review.
            </Text>
          </View>
          {editable ? (
            <InlineActionButton label={t('onboarding.preview.addCategory')} onPress={onAddCategory} />
          ) : null}
        </View>

        <View style={styles.summaryGrid}>
          {[
            { label: 'Categories', value: summary.categories },
            { label: 'KPIs', value: summary.kpis },
            { label: 'Activities', value: summary.activities },
            { label: 'Recommended', value: summary.recommended },
          ].map((item) => (
            <View
              key={item.label}
              style={[
                styles.summaryCard,
                {
                  backgroundColor: theme.secondaryBackground,
                  borderColor: theme.cardBorder,
                  borderRadius: theme.borderRadius.md,
                },
              ]}>
              <Text style={[styles.summaryValue, { color: theme.textPrimary }]}>{item.value}</Text>
              <Text style={[styles.summaryLabel, { color: theme.textMuted }]}>{item.label}</Text>
            </View>
          ))}
        </View>

        {setup.categories.length === 0 ? (
          <EmptyState
            title={t('onboarding.preview.noCategories')}
            subtitle={t('onboarding.preview.noCategoriesMessage')}
          />
        ) : (
          setup.categories.map((category) => {
            const detailCount = category.kpis.reduce((sum, kpi) => sum + kpi.activities.length, 0);
            const expanded = expandedLookup[category.id];

            return (
              <View
                key={category.id}
                style={[
                  styles.categoryCard,
                  {
                    backgroundColor: theme.secondaryBackground,
                    borderColor: theme.cardBorder,
                    borderRadius: theme.borderRadius.md,
                  },
                ]}>
                <View style={styles.blockHeaderRow}>
                  <Pressable
                    onPress={() =>
                      setExpandedCategoryIds((current) => ({
                        ...current,
                        [category.id]: !expanded,
                      }))
                    }
                    style={styles.categoryHeaderButton}>
                    <View style={styles.categoryHeaderText}>
                      <InputLabel>{t('onboarding.preview.categoryLabel')}</InputLabel>
                      <PreviewTextInput
                        editable={editable}
                        value={category.name}
                        onChangeText={(value) => onUpdateCategoryName(category.id, value)}
                      />
                      <Text style={[styles.categoryMeta, { color: theme.textMuted }]}>
                        {`${category.kpis.length} KPIs • ${detailCount} activities`}
                      </Text>
                    </View>
                    <View style={styles.detailsToggle}>
                      <Text style={[styles.detailsToggleText, { color: theme.primary }]}>
                        {expanded ? 'Hide Details' : 'View Details'}
                      </Text>
                      <MaterialIcons
                        name={(expanded ? 'expand-less' : 'expand-more') as never}
                        size={22}
                        color={theme.textMuted}
                      />
                    </View>
                  </Pressable>
                  {editable ? (
                    <InlineActionButton
                      label={t('onboarding.preview.deleteCategory')}
                      tone="danger"
                      onPress={() => onDeleteCategory(category.id)}
                    />
                  ) : null}
                </View>

                {expanded ? (
                  <>
                    <View style={styles.categoryActionsRow}>
                      {editable ? (
                        <InlineActionButton
                          label={t('onboarding.preview.addKpi')}
                          onPress={() => onAddKpi(category.id)}
                        />
                      ) : null}
                    </View>

                    {category.kpis.length === 0 ? (
                      <Text style={[styles.emptyHint, { color: theme.textSecondary }]}>
                        {t('onboarding.preview.noKpis')}
                      </Text>
                    ) : (
                      category.kpis.map((kpi) => (
                        <KpiEditor
                          key={kpi.id}
                          category={category}
                          kpi={kpi}
                          editable={editable}
                          onUpdateKpi={onUpdateKpi}
                          onDeleteKpi={onDeleteKpi}
                          onAddActivity={onAddActivity}
                          onUpdateActivity={onUpdateActivity}
                          onDeleteActivity={onDeleteActivity}
                        />
                      ))
                    )}
                  </>
                ) : null}
              </View>
            );
          })
        )}
      </SectionCard>

      {setup.relationships.length > 0 || editable ? (
        <SectionCard>
          <View style={styles.headerRow}>
            <View style={{ flex: 1 }}>
              <Text style={[styles.sectionTitle, { color: theme.textPrimary }]}>
                {t('onboarding.preview.relationshipTrackersTitle')}
              </Text>
              <Text style={[styles.sectionSubtitle, { color: theme.textSecondary }]}>
                {t('onboarding.preview.relationshipTrackersSubtitle')}
              </Text>
            </View>
            {editable ? (
              <InlineActionButton
                label={t('onboarding.preview.addRelationship')}
                onPress={onAddRelationship}
              />
            ) : null}
          </View>

          {setup.relationships.length === 0 ? (
            <Text style={[styles.emptyHint, { color: theme.textSecondary }]}>
              Relationship trackers will appear here based on your selections.
            </Text>
          ) : (
            setup.relationships.map((relationship) => (
              <RelationshipEditor
                key={relationship.id}
                relationship={relationship}
                editable={editable}
                onUpdateRelationship={onUpdateRelationship}
                onDeleteRelationship={onDeleteRelationship}
              />
            ))
          )}
        </SectionCard>
      ) : null}

      <SectionCard>
        <Text style={[styles.sectionTitle, { color: theme.textPrimary }]}>
          {t('onboarding.preview.reminderPreferencesTitle')}
        </Text>
        <Text style={[styles.sectionSubtitle, { color: theme.textSecondary }]}>
          {t('onboarding.preview.reminderPreferencesSubtitle')}
        </Text>

        <View style={styles.toggleRow}>
          <Text style={[styles.toggleLabel, { color: theme.textPrimary }]}>
            {t('onboarding.preview.kpiReminders')}
          </Text>
          <ToggleChip
            label={setup.reminderPreferences.kpiReminders ? t('common.on') : t('common.off')}
            selected={setup.reminderPreferences.kpiReminders}
            onPress={() =>
              onUpdateReminderPreference('kpiReminders', !setup.reminderPreferences.kpiReminders)
            }
          />
        </View>
        <View style={styles.toggleRow}>
          <Text style={[styles.toggleLabel, { color: theme.textPrimary }]}>
            {t('onboarding.preview.relationshipReminders')}
          </Text>
          <ToggleChip
            label={setup.reminderPreferences.relationshipReminders ? t('common.on') : t('common.off')}
            selected={setup.reminderPreferences.relationshipReminders}
            onPress={() =>
              onUpdateReminderPreference(
                'relationshipReminders',
                !setup.reminderPreferences.relationshipReminders
              )
            }
          />
        </View>
        <View style={styles.toggleRow}>
          <Text style={[styles.toggleLabel, { color: theme.textPrimary }]}>
            {t('onboarding.preview.weeklyReview')}
          </Text>
          <ToggleChip
            label={setup.reminderPreferences.weeklyReview ? t('common.on') : t('common.off')}
            selected={setup.reminderPreferences.weeklyReview}
            onPress={() =>
              onUpdateReminderPreference('weeklyReview', !setup.reminderPreferences.weeklyReview)
            }
          />
        </View>
      </SectionCard>
    </View>
  );
}

